# Force LF for all text files. Critical for the CSP: index.html pins its inline
# scripts by SHA-256 hash (computed over LF content), so a CRLF checkout under
# core.autocrlf=true would change the bytes and the browser would block them.
* text=auto eol=lf

# Windows batch files must keep CRLF — cmd.exe silently fails on LF-only .bat.
*.bat text eol=crlf

# Binary assets — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.webp binary
